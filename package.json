{
  "name": "@juz/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "design.juz.pl - shadcn-compatible design system for juz.pl.",
  "author": "Rafał Mazur",
  "homepage": "https://design.juz.pl",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -b && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --host 127.0.0.1",
    "build-storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "serve-storybook": "vite preview --host 127.0.0.1 --port 6006 --strictPort --outDir storybook-static",
    "test:storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 test-storybook --url http://127.0.0.1:6006",
    "test:storybook:ci": "start-server-and-test serve-storybook http://127.0.0.1:6006 test:storybook",
    "qa": "npm run build && npm run build-storybook && npm run test:storybook:ci"
  },
  "dependencies": {
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-tooltip": "^1.2.8",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "tailwind-merge": "^2.6.0"
  },
  "devDependencies": {
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test-runner": "^0.22.1",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "start-server-and-test": "^2.1.5",
    "storybook": "8.6.18",
    "tailwindcss": "^3.4.17",
    "typescript": "^5.7.2",
    "vite": "^6.0.7"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
