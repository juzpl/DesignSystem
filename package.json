{
  "name": "@juz/design-system",
  "version": "0.1.0",
  "private": true,
  "description": "DesignSystem - shadcn-compatible design system for juz.pl.",
  "author": "Rafał Mazur",
  "homepage": "https://juzpl.github.io/DesignSystem/",
  "type": "module",
  "packageManager": "pnpm@9.15.9",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "src",
    "components.json"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./src/index.ts"
    },
    "./atoms/*": "./src/components/ui/*.tsx",
    "./molecules/*": "./src/components/ds/*.tsx",
    "./layout/*": "./src/components/layout/*.tsx",
    "./lib/utils": "./src/lib/utils.ts",
    "./styles.css": {
      "default": "./dist/styles.css"
    },
    "./styles.source.css": "./src/styles/globals.css"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "react-dom": "^18.0.0 || ^19.0.0"
  },
  "sideEffects": [
    "**/*.css"
  ],
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 5174",
    "build": "tsc -b && vite build",
    "build:lib": "vite build --config vite.lib.config.ts",
    "prepare": "pnpm build:lib",
    "preview": "vite preview --host 127.0.0.1 --port 4174",
    "storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook dev -p 6006 --host 127.0.0.1",
    "build-storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 storybook build",
    "serve-storybook": "vite preview --host 127.0.0.1 --port 6006 --strictPort --outDir storybook-static",
    "test:storybook": "HOME=$PWD/.storybook-home STORYBOOK_DISABLE_TELEMETRY=1 test-storybook --url http://127.0.0.1:6006",
    "test:storybook:ci": "start-server-and-test serve-storybook http://127.0.0.1:6006 test:storybook",
    "qa": "npm run build && npm run build-storybook && npm run test:storybook:ci",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "release": "pnpm build:lib && changeset publish",
    "visual:snap": "node tests/visual/snap.mjs tests/visual/current",
    "visual:baseline": "node tests/visual/snap.mjs tests/visual/baseline",
    "visual:diff": "python3 tests/visual/diff.py",
    "visual:run": "pnpm visual:snap && pnpm visual:diff",
    "visual:check": "start-server-and-test serve-storybook http://127.0.0.1:6006 visual:run",
    "size": "size-limit"
  },
  "dependencies": {
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-aspect-ratio": "^1.1.8",
    "@radix-ui/react-avatar": "^1.1.11",
    "@radix-ui/react-checkbox": "^1.3.3",
    "@radix-ui/react-context-menu": "^2.2.16",
    "@radix-ui/react-dialog": "^1.1.15",
    "@radix-ui/react-dropdown-menu": "^2.1.16",
    "@radix-ui/react-hover-card": "^1.1.15",
    "@radix-ui/react-label": "^2.1.7",
    "@radix-ui/react-menubar": "^1.1.16",
    "@radix-ui/react-popover": "^1.1.15",
    "@radix-ui/react-progress": "^1.1.8",
    "@radix-ui/react-radio-group": "^1.3.8",
    "@radix-ui/react-scroll-area": "^1.2.10",
    "@radix-ui/react-select": "^2.2.6",
    "@radix-ui/react-separator": "^1.1.8",
    "@radix-ui/react-slider": "^1.3.6",
    "@radix-ui/react-slot": "^1.2.3",
    "@radix-ui/react-switch": "^1.2.6",
    "@radix-ui/react-tabs": "^1.1.13",
    "@radix-ui/react-toggle": "^1.1.10",
    "@radix-ui/react-toggle-group": "^1.1.11",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-table": "^8.21.3",
    "bwip-js": "^4.10.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "date-fns": "^4.3.0",
    "embla-carousel-react": "^8.6.0",
    "input-otp": "^1.4.2",
    "lucide-react": "^0.468.0",
    "next-themes": "^0.4.6",
    "react": "^19.0.0",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.0.0",
    "react-dropzone": "^15.0.0",
    "recharts": "^3.8.1",
    "sonner": "^2.0.7",
    "tailwind-merge": "^2.6.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.0",
    "@size-limit/preset-small-lib": "^12.1.0",
    "@storybook/addon-a11y": "8.6.18",
    "@storybook/addon-essentials": "8.6.18",
    "@storybook/addon-interactions": "8.6.18",
    "@storybook/addon-links": "8.6.18",
    "@storybook/addon-themes": "8.6.18",
    "@storybook/blocks": "8.6.18",
    "@storybook/react": "8.6.18",
    "@storybook/react-vite": "8.6.18",
    "@storybook/test": "^8.6.15",
    "@storybook/test-runner": "^0.22.1",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/node": "^22.10.5",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "playwright": "^1.60.0",
    "postcss": "^8.4.49",
    "size-limit": "^12.1.0",
    "start-server-and-test": "^2.1.5",
    "storybook": "8.6.18",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.7.2",
    "vite": "^6.0.7",
    "vite-plugin-dts": "^5.0.1"
  },
  "overrides": {
    "uuid": "^11.1.1"
  },
  "license": "SEE LICENSE IN LICENSE.md"
}
